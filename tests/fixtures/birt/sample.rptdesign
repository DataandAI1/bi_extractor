<?xml version="1.0" encoding="UTF-8"?>
<report xmlns="http://www.eclipse.org/birt/2005/design" version="3.2.23"
        id="1">
  <property name="createdBy">Eclipse BIRT Designer</property>
  <data-sources>
    <oda-data-source extensionID="org.eclipse.birt.report.data.oda.jdbc"
                     name="SalesDB" id="5">
      <property name="odaDriverClass">com.mysql.jdbc.Driver</property>
      <property name="odaURL">jdbc:mysql://localhost:3306/sales</property>
      <property name="odaDatabase">sales</property>
      <property name="odaUser">reporter</property>
    </oda-data-source>
  </data-sources>
  <data-sets>
    <oda-data-set extensionID="org.eclipse.birt.report.data.oda.jdbc.JdbcSelectDataSet"
                  name="SalesDataSet" id="6" dataSource="SalesDB">
      <xml-property name="queryText"><![CDATA[SELECT order_id, customer_name, amount, region FROM orders WHERE year = ?]]></xml-property>
      <structure name="cachedMetaData">
        <list-property name="resultSetColumns">
          <structure>
            <property name="name">order_id</property>
            <property name="dataType">integer</property>
          </structure>
          <structure>
            <property name="name">customer_name</property>
            <property name="dataType">string</property>
          </structure>
          <structure>
            <property name="name">amount</property>
            <property name="dataType">decimal</property>
          </structure>
          <structure>
            <property name="name">region</property>
            <property name="dataType">string</property>
          </structure>
        </list-property>
      </structure>
    </oda-data-set>
  </data-sets>
  <parameters>
    <scalar-parameter name="reportYear" id="10">
      <property name="dataType">integer</property>
      <property name="defaultValue">2024</property>
      <property name="promptText">Report Year</property>
    </scalar-parameter>
    <scalar-parameter name="regionFilter" id="11">
      <property name="dataType">string</property>
      <property name="defaultValue">ALL</property>
      <property name="promptText">Region</property>
    </scalar-parameter>
  </parameters>
  <body>
    <grid name="headerGrid" id="20">
      <property name="width">100%</property>
    </grid>
    <table name="salesTable" id="21">
      <property name="dataSet">SalesDataSet</property>
    </table>
    <label name="footerLabel" id="22">
      <text-property name="text">Confidential</text-property>
    </label>
  </body>
</report>
