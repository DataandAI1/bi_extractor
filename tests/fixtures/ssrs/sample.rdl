<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition">

  <DataSources>
    <DataSource Name="SalesDB">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=srv01;Initial Catalog=Sales;Integrated Security=True</ConnectString>
      </ConnectionProperties>
    </DataSource>
    <DataSource Name="HRDataSource">
      <ConnectionProperties>
        <DataProvider>OLEDB</DataProvider>
        <ConnectString>Provider=SQLOLEDB;Data Source=hr-srv;Initial Catalog=HR</ConnectString>
      </ConnectionProperties>
    </DataSource>
    <DataSource Name="SharedSource">
      <DataSourceReference>/DataSources/CorporateDB</DataSourceReference>
    </DataSource>
  </DataSources>

  <DataSets>
    <DataSet Name="SalesDataSet">
      <Query>
        <DataSourceName>SalesDB</DataSourceName>
        <CommandText>SELECT OrderID, CustomerName, Amount, OrderDate FROM dbo.Orders WHERE OrderDate &gt;= @StartDate</CommandText>
      </Query>
      <Fields>
        <Field Name="OrderID">
          <DataField>OrderID</DataField>
          <TypeName>System.Int32</TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="Amount">
          <DataField>Amount</DataField>
          <TypeName>System.Decimal</TypeName>
        </Field>
        <Field Name="OrderDate">
          <DataField>OrderDate</DataField>
          <TypeName>System.DateTime</TypeName>
        </Field>
        <Field Name="TotalWithTax">
          <Value>=Fields!Amount.Value * 1.1</Value>
          <TypeName>System.Decimal</TypeName>
        </Field>
        <Field Name="DisplayName">
          <Value>=Fields!CustomerName.Value &amp; " - " &amp; CStr(Fields!OrderID.Value)</Value>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!Amount.Value</FilterExpression>
          <Operator>GreaterThan</Operator>
          <FilterValues>
            <FilterValue>100</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="EmployeeDataSet">
      <Query>
        <DataSourceName>HRDataSource</DataSourceName>
        <CommandText>SELECT EmployeeID, FullName, Department FROM dbo.Employees</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeID">
          <DataField>EmployeeID</DataField>
          <TypeName>System.Int32</TypeName>
        </Field>
        <Field Name="FullName">
          <DataField>FullName</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="Department">
          <DataField>Department</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>

  <ReportParameters>
    <ReportParameter Name="StartDate">
      <DataType>DateTime</DataType>
      <Prompt>Start Date</Prompt>
      <DefaultValue>
        <Values>
          <Value>2024-01-01</Value>
        </Values>
      </DefaultValue>
    </ReportParameter>
    <ReportParameter Name="Region">
      <DataType>String</DataType>
      <Prompt>Select Region</Prompt>
      <ValidValues>
        <ParameterValue>
          <Value>North</Value>
          <Label>North</Label>
        </ParameterValue>
        <ParameterValue>
          <Value>South</Value>
          <Label>South</Label>
        </ParameterValue>
        <ParameterValue>
          <Value>East</Value>
          <Label>East</Label>
        </ParameterValue>
        <ParameterValue>
          <Value>West</Value>
          <Label>West</Label>
        </ParameterValue>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="InternalFilter">
      <DataType>Integer</DataType>
      <Hidden>true</Hidden>
      <DefaultValue>
        <Values>
          <Value>0</Value>
        </Values>
      </DefaultValue>
    </ReportParameter>
  </ReportParameters>

  <Body>
    <ReportItems>
      <Tablix Name="SalesTablix">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>2in</Width></TablixColumn>
            <TablixColumn><Width>2in</Width></TablixColumn>
            <TablixColumn><Width>1.5in</Width></TablixColumn>
            <TablixColumn><Width>1.5in</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <TablixRow>
              <TablixCells>
                <TablixCell>
                  <CellContents>
                    <TextBox Name="OrderID_Cell">
                      <Value>=Fields!OrderID.Value</Value>
                    </TextBox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <TextBox Name="CustomerName_Cell">
                      <Value>=Fields!CustomerName.Value</Value>
                    </TextBox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <TextBox Name="Amount_Cell">
                      <Value>=Fields!Amount.Value</Value>
                    </TextBox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <TextBox Name="TotalWithTax_Cell">
                      <Value>=Fields!TotalWithTax.Value</Value>
                    </TextBox>
                  </CellContents>
                </TablixCell>
              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>
        <DataSetName>SalesDataSet</DataSetName>
        <Filters>
          <Filter>
            <FilterExpression>=Fields!OrderDate.Value</FilterExpression>
            <Operator>GreaterThanOrEqual</Operator>
            <FilterValues>
              <FilterValue>=Parameters!StartDate.Value</FilterValue>
            </FilterValues>
          </Filter>
        </Filters>
      </Tablix>
      <Chart Name="SalesChart">
        <DataSetName>SalesDataSet</DataSetName>
        <ChartSeriesHierarchy>
          <ChartMembers>
            <ChartMember><Label>=Fields!OrderDate.Value</Label></ChartMember>
          </ChartMembers>
        </ChartSeriesHierarchy>
        <ChartCategoryHierarchy>
          <ChartMembers>
            <ChartMember><Label>=Fields!Amount.Value</Label></ChartMember>
          </ChartMembers>
        </ChartCategoryHierarchy>
      </Chart>
      <TextBox Name="ReportTitle">
        <Value>Sales Report</Value>
      </TextBox>
    </ReportItems>
  </Body>

</Report>
